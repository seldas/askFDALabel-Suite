{
  "name": "frontend",
  "version": "1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-frontend.js",
    "dev:backend": "node scripts/start-backend.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node scripts/start-frontend.js",
    "start:backend": "cross-env NODE_ENV=production node scripts/start-backend.js",
    "prod": "npm run build && concurrently \"npm run start\" \"npm run start:backend\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "axios": "^1.13.5",
    "cross-env": "^10.1.0",
    "datatables.net": "^2.3.7",
    "datatables.net-autofill-bs5": "^2.7.1",
    "datatables.net-bs5": "^2.3.7",
    "datatables.net-buttons-bs5": "^3.2.6",
    "datatables.net-colreorder-bs5": "^2.1.2",
    "datatables.net-react": "^1.0.1",
    "datatables.net-responsive-bs5": "^3.0.8",
    "datatables.net-rowgroup-bs5": "^1.6.0",
    "datatables.net-scroller-bs5": "^2.4.3",
    "datatables.net-searchpanes-bs5": "^2.3.5",
    "dotenv": "^17.3.1",
    "file-saver": "^2.0.5",
    "jquery": "^4.0.0",
    "lodash": "^4.17.23",
    "next": "16.1.6",
    "pnpm": "^10.29.2",
    "react": "^19.2.4",
    "react-data-table-component": "^7.7.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/datatables.net": "^1.12.3",
    "@types/file-saver": "^2.0.7",
    "@types/jquery": "^3.5.33",
    "@types/lodash": "^4.17.23",
    "@types/node": "25.2.3",
    "@types/react": "19.2.13",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "typescript": "5.9.3"
  }
}
