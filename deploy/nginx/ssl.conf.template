server {
    listen 443 ssl;
    http2 on;
    server_name _;
    ssl_certificate /etc/nginx/certs/askfdalabel.crt;
    ssl_certificate_key /etc/nginx/certs/askfdalabel.key;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location = / {
        return 302 /askfdalabel/;
    }

    location ^~ /askfdalabel_api/ {
        rewrite ^/askfdalabel_api/(.*)$ /$1 break;
        proxy_pass http://backend:8842;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Prefix /askfdalabel_api;
        proxy_set_header Connection "";
        proxy_read_timeout 90s;
        proxy_set_header Upgrade $http_upgrade;
    }

    location ^~ /askfdalabel {
        proxy_pass http://frontend:8841;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Prefix /askfdalabel;
        proxy_set_header Connection "";
        proxy_read_timeout 90s;
        proxy_set_header Upgrade $http_upgrade;
    }
}
