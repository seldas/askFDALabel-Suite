<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>askFDALabel</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 40px; }
    .btn { display:inline-block; margin: 8px; padding: 12px 16px; border-radius: 8px; border: 1px solid #ccc; text-decoration:none; }
    .btn.disabled { color:#999; border-color:#eee; pointer-events:none; }
  </style>
</head>
<body>
  <h1>askFDALabel</h1>
  <p>Select an app:</p>

  <!-- Search -->
  <a class="btn {{SEARCH_CLASS}}" href="/search">Search</a>

  <!-- Analysis -->
  <a class="btn {{ANALYSIS_CLASS}}" href="/analysis/">Analysis</a>

  <!-- DrugToxDB -->
  <a class="btn {{DRUG_CLASS}}" href="/drugtoxdb/">DrugToxDB</a>

  <script>
    const enableSearch = "{{ENABLE_SEARCH}}" === "1";
    const enableAnalysis = "{{ENABLE_ANALYSIS}}" === "1";
    const enableDrug = "{{ENABLE_DRUGTOXDB}}" === "1";

    const a = document.querySelectorAll("a.btn");
    const searchBtn = a[0], analysisBtn = a[1], drugBtn = a[2];

    if (!enableSearch) searchBtn.classList.add("disabled");
    if (!enableAnalysis) analysisBtn.classList.add("disabled");
    if (!enableDrug) drugBtn.classList.add("disabled");

    // If search is enabled, we want "/" to be Search app, not this landing page.
    // This page is only used when search is disabled.
  </script>
</body>
</html>
